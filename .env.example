# Claude API key — the chat model
ANTHROPIC_API_KEY=sk-ant-...

# Sprites API token (org/projectNumber/tokenId/secret) — the sandbox
# https://sprites.dev
SPRITES_API_KEY=

# Optional: the Claude model (default claude-sonnet-5)
# ANTHROPIC_MODEL=claude-sonnet-5

# Optional: override the Sprites API base URL and the listen port
# SPRITES_API_URL=https://api.sprites.dev
# PORT=8080
